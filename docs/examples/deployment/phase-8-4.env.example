# Phase 8.4 deployment contract example. Never commit real values.

# CURRENTLY IMPLEMENTED: authentication
BIOINFO_REQUIRE_API_KEY=true
BIOINFO_API_KEY=<set-in-deployment-secret-store>
BIOINFO_API_KEY_HEADER=X-Bioinfo-API-Key

# CURRENTLY IMPLEMENTED: request controls
BIOINFO_MAX_REQUEST_BYTES=10485760
BIOINFO_REQUEST_TIMEOUT_SECONDS=120
BIOINFO_MAX_METADATA_BYTES=1048576
BIOINFO_MAX_COUNT_MATRIX_BYTES=10485760
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SCOPE=ip
RATE_LIMIT_EXEMPT_PATHS=/health,/docs,/openapi.json

# CURRENTLY IMPLEMENTED: task input, artifact, and SQLite roots.
# Values are deployment-local examples and must be mounted outside public web roots.
BIOINFO_INPUT_ROOT=./runtime/inputs
BIOINFO_OUTPUT_ROOT=./runtime/artifacts
BIOINFO_TASK_STORE_PATH=./runtime/state/tasks.sqlite3

# CURRENTLY IMPLEMENTED: optional runner selection
RUN_MODE=mock
RSCRIPT_EXECUTABLE=Rscript
DOCKER_R_IMAGE=bioinformatics-agent-r-bulk-rnaseq:reviewed-version
DOCKER_EXECUTABLE=docker
DOCKER_WORKDIR=<container-workdir-configured-at-deploy>

# PLANNED / GATE INPUT ONLY: these variables are not consumed by current runtime code.
BIOINFO_PUBLIC_BASE_URL=https://bioinformatics.example.invalid
BIOINFO_ENVIRONMENT=staging
BIOINFO_LOG_LEVEL=INFO
BIOINFO_TRUSTED_PROXY_MODE=explicit_allowlist_required
BIOINFO_DATA_RETENTION_DAYS=<define-before-staging>
